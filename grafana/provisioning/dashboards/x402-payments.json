      "title": "Request Rate by Endpoint",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (span_name) (rate(calls_total{span_name=~\"GET /.*|POST /.*\"}[$__rate_interval]))",
          "legendFormat": "{{span_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 23,
      "title": "Endpoint Details",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "unit": "ms"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Endpoint" },
            "properties": [{ "id": "custom.width", "value": 250 }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 25 },
      "id": 9,
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Avg Latency (ms)" }],
        "footer": { "show": false }
      },
      "title": "Endpoint Avg Latency (last 5m)",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "topk(15, sum by (span_name) (rate(duration_milliseconds_sum{span_name=~\"GET /.*|POST /.*\"}[5m])) / sum by (span_name) (rate(duration_milliseconds_count{span_name=~\"GET /.*|POST /.*\"}[5m])))",
          "legendFormat": "{{span_name}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "span_name": "Endpoint",
              "Value": "Avg Latency (ms)"
            },
            "excludeByName": { "Time": true }
          }
        }
      ]
