# Crossmint server-side API key (https://www.crossmint.com/console)
# Production key: sk_production_...
CROSSMINT_API_KEY=sk_production_YOUR_KEY_HERE

# Your Crossmint smart wallet address on Solana mainnet
# Create with: npm run setup-wallet
CROSSMINT_WALLET=YOUR_WALLET_ADDRESS_HERE

# Solana mainnet RPC
RPC_URL=https://api.mainnet-beta.solana.com

# Facilitator URL
FACILITATOR_URL=https://facilitator.ultravioletadao.xyz

# Paywall server port
SERVER_PORT=3402
